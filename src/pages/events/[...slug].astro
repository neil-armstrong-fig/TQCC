---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import EventDetail from "../../components/events/EventDetail.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const getStaticPaths = (async () => {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}) satisfies GetStaticPaths;

const { event } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const redirectUrl = event.data.pageUrl ? `${baseUrl}${event.data.pageUrl}` : null;
---

{redirectUrl ? (
  <BaseLayout title={event.data.title} description={event.data.description}>
    <meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
    <section class="py-16 text-center">
      <p>Redirecting to the <a href={redirectUrl} class="text-tqcc-pink underline">{event.data.title} page</a>…</p>
    </section>
  </BaseLayout>
) : (
  <EventDetail event={event} />
)}
