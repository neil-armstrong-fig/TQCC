---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const events = await getCollection("events");
const event = events.find((e) => e.id === "summer-solstice-sportive-2026")!;
const { Content } = await render(event);
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const eventDate = event.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
const eventTime = event.data.date.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit" });
---

<BaseLayout
  title="Summer Solstice Sportive | TQCC"
  description={event.data.description}
>
  <!-- Hero -->
  <section class="bg-tqcc-black text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-tqcc-pink font-semibold uppercase tracking-widest mb-3">Annual Event</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-tqcc-yellow mb-4">Summer Solstice Sportive</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
        An evening sportive open to all abilities — TQCC members and non-members welcome.
        Celebrating the longest days of the year with great roads, great people, and hot food at the finish.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4">

      <!-- Key details cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        <div class="text-center p-5 bg-tqcc-gray-light rounded-lg">
          <span class="text-2xl font-bold text-tqcc-yellow">{eventDate}</span>
          <p class="mt-1 text-sm text-tqcc-gray">2026 Date</p>
        </div>
        <div class="text-center p-5 bg-tqcc-gray-light rounded-lg">
          <span class="distance-string text-2xl font-bold text-tqcc-yellow" data-distance={event.data.distance}>{event.data.distance}</span>
          <p class="mt-1 text-sm text-tqcc-gray">Distance</p>
        </div>
        <div class="text-center p-5 bg-tqcc-gray-light rounded-lg">
          <span class="text-2xl font-bold text-tqcc-yellow">{eventTime}</span>
          <p class="mt-1 text-sm text-tqcc-gray">Ride Out</p>
        </div>
        <div class="text-center p-5 bg-tqcc-gray-light rounded-lg">
          <span class="text-2xl font-bold text-tqcc-pink">All</span>
          <p class="mt-1 text-sm text-tqcc-gray">Abilities Welcome</p>
        </div>
      </div>

      <!-- Sportive poster -->
      {event.data.image && (
        <div class="mb-12">
          <img
            src={`${baseUrl}${event.data.image}`}
            alt="Summer Solstice Sportive 2026 poster"
            class="w-full rounded-lg shadow-lg"
          />
        </div>
      )}

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-12 bg-tqcc-black text-white p-8 rounded-lg text-center">
        <h2 class="text-2xl font-bold text-tqcc-yellow mb-3">Registration Coming Soon</h2>
        <p class="text-white/80 mb-6">
          Registration details for the 2026 Solstice Sportive will be announced in spring 2026.
          Follow us on social media to be the first to know.
        </p>
        <a
          href={`${baseUrl}/contact`}
          class="inline-block bg-tqcc-yellow text-tqcc-black font-bold px-8 py-3 rounded-lg hover:bg-tqcc-yellow-dark transition-colors"
        >
          Get in Touch
        </a>
      </div>

    </div>
  </section>
</BaseLayout>
